{
  "name": "spmc",
  "version": "0.2.0-alpha",
  "description": "Social Publishing Mission Control — AI-native MCP server for X, Instagram, TikTok, Facebook, Threads, and Bluesky",
  "author": "towb",
  "type": "module",
  "main": "index.js",
  "bin": {
    "spmc": "./run.js"
  },
  "files": [
    "adapters/",
    "media/",
    "queue/store.js",
    "scheduler/",
    "index.js",
    "run.js",
    "start.js",
    "env.example"
  ],
  "scripts": {
    "start": "node run.js",
    "dev": "node --watch index.js",
    "scheduler": "node scheduler/index.js",
    "scheduler:dev": "node --watch scheduler/index.js",
    "test": "node --test \"test/*.test.mjs\"",
    "test:smoke": "node test/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "sharp": "^0.35.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp", "social-media", "publishing", "x", "twitter", "instagram",
    "tiktok", "facebook", "threads", "bluesky", "ai-native", "queue"
  ],
  "license": "MIT"
}
