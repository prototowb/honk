# ─── social-publisher credentials ────────────────────────────────────────────
#
# RECOMMENDED: place this file at %USERPROFILE%\.claude\social-publisher.env
#   e.g. C:\Users\tobia\.claude\social-publisher.env
#
# This location is outside the plugin bundle so it survives reinstalls.
# The server also checks for a .env next to run.js as a local-dev fallback.
#
# Copy this file to the recommended location, rename it social-publisher.env,
# and fill in your real values. Never commit the filled-in file to git.
# ─────────────────────────────────────────────────────────────────────────────

# X (Twitter)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Instagram Graph API
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Facebook (can reuse the Instagram token if it has pages_manage_posts scope)
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Threads (separate app/credentials from Instagram & Facebook)
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# TikTok
TIKTOK_ACCESS_TOKEN=

# Bluesky (app password — not your account password)
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
