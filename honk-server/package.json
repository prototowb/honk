{
  "name": "honk",
  "version": "0.3.0-alpha",
  "description": "Honk — AI-native MCP server for X, Instagram, TikTok, Facebook, Threads, and Bluesky",
  "author": "towb",
  "type": "module",
  "main": "index.js",
  "bin": {
    "honk": "./run.js",
    "honk-start": "./start.js"
  },
  "files": [
    "adapters/",
    "lib/",
    "media/",
    "queue/store.js",
    "scheduler/",
    "index.js",
    "run.js",
    "start.js",
    "env.example"
  ],
  "scripts": {
    "start": "node run.js",
    "dev": "node --watch index.js",
    "scheduler": "node scheduler/index.js",
    "scheduler:dev": "node --watch scheduler/index.js",
    "test": "node --test \"test/*.test.mjs\"",
    "test:smoke": "node test/smoke.mjs",
    "pack:smoke": "node test/pack-smoke.mjs",
    "prepublishOnly": "npm test && npm --prefix .. run build:check && npm run pack:smoke",
    "version": "npm --prefix .. run build && git -C .. add -u"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "sharp": "^0.35.0"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "keywords": [
    "mcp", "social-media", "publishing", "x", "twitter", "instagram",
    "tiktok", "facebook", "threads", "bluesky", "ai-native", "queue"
  ],
  "license": "MIT"
}
