# Social Publishing Mission Control — Environment Variables
#
# PREFERRED: Copy this to %USERPROFILE%\.claude\spmc.env (Windows) or
#            ~/.claude/spmc.env (macOS/Linux). This location survives
#            plugin reinstalls and is auto-loaded by spmc-server/run.js.
#
# FALLBACK:  Copy to spmc-server/.env for local dev.
# NEVER commit either file.

# ── X (Twitter) — OAuth 1.0a ─────────────────────────────────────────────
# Create an app at developer.twitter.com and generate access tokens.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Instagram / Facebook — Meta Graph API ────────────────────────────────
# One system-user EAA token with pages_manage_posts covers both.
# Get from Meta Business Suite > System Users > Generate token.
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# ── TikTok — Content Posting API ─────────────────────────────────────────
# Requires OAuth user-authorization flow (see TikTok Developer Portal).
# Token needs the video.publish scope.
TIKTOK_ACCESS_TOKEN=

# ── Threads — Threads API ────────────────────────────────────────────────
# Threads API (threads_basic + threads_content_publish scopes).
# Same Meta app infrastructure as Instagram but a separate token.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── Bluesky — AT Protocol ────────────────────────────────────────────────
# No OAuth — just an app password (never your real account password).
# Generate at: https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=yourname.bsky.social
BLUESKY_APP_PASSWORD=

# ── Media pipeline — CDN upload (for Instagram / TikTok local files) ─────
# Provider is auto-selected: Cloudinary first, imgbb fallback.
# Cloudinary supports images + videos. imgbb supports images only.

# Cloudinary — get from cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# imgbb — get from api.imgbb.com
IMGBB_API_KEY=

# ── Multi-account support ────────────────────────────────────────────────
# Append __ACCOUNTNAME (uppercase) to any credential key to define a named
# account. Pass account: "brand" to any publishing tool to use it.
# The default (unprefixed) credentials are always the fallback.
#
# Example: a second X account named "brand"
X_API_KEY__BRAND=
X_API_SECRET__BRAND=
X_ACCESS_TOKEN__BRAND=
X_ACCESS_TOKEN_SECRET__BRAND=
#
# Example: a second Instagram/Facebook account named "brand"
INSTAGRAM_USER_ID__BRAND=
INSTAGRAM_ACCESS_TOKEN__BRAND=
FACEBOOK_PAGE_ID__BRAND=
FACEBOOK_ACCESS_TOKEN__BRAND=
#
# Example: a second TikTok account named "brand"
TIKTOK_ACCESS_TOKEN__BRAND=
#
# Example: a second Threads account named "brand"
THREADS_USER_ID__BRAND=
THREADS_ACCESS_TOKEN__BRAND=
#
# Example: a second Bluesky account named "brand"
BLUESKY_IDENTIFIER__BRAND=brandbsky.bsky.social
BLUESKY_APP_PASSWORD__BRAND=
